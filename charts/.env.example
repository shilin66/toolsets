# API 密钥配置
CHART_API_KEY=default-secret-key

# 存储类型配置: local 或 minio
STORAGE_TYPE=local

# ===== MinIO 配置 (当 STORAGE_TYPE=minio 时需要配置) =====
# MinIO 服务地址 (不包含 http/https)
MINIO_ENDPOINT=localhost:9000

# MinIO 访问凭证
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key

# MinIO Bucket 名称
MINIO_BUCKET=charts

# 是否使用 HTTPS 连接 MinIO
MINIO_SECURE=false

# 可选: 自定义公网访问地址 (如使用 CDN 或反向代理)
# 留空则使用 MINIO_ENDPOINT 生成链接
# 示例: https://cdn.example.com 或 https://minio.example.com
MINIO_PUBLIC_URL=
