# 邮箱配置
IMAP_SERVER=
IMAP_PORT=
IMAP_USE_SSL=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
# API配置
API_URL=
API_TOKEN=
API_PORT=5001
API_TIMEOUT=600

# 检查邮件间隔（秒）
CHECK_INTERVAL=30
# 是否标记已读
MARK_AS_READ=false
# 邮件过滤时间（小时）
EMAIL_HOURS_FILTER=3
# 邮箱服务器是否支持IDLE模式
IMAP_IDLE_SUPPORT=true
# IDLE模式超时时间（秒），建议30分钟
IDLE_TIMEOUT=1200
# IDLE连接断开后重连延迟（秒）
IDLE_RECONNECT_DELAY=5
# 每批处理的最大邮件数量
MAX_EMAILS_PER_BATCH=50
# 搜索操作超时时间（秒）
SEARCH_TIMEOUT=30

# 并发配置
# 是否启用并发处理
CONCURRENT_PROCESSING=true
# 最大并发处理邮件数量
MAX_CONCURRENT_EMAILS=10

# 日志配置
LOG_LEVEL=DEBUG

# API Key 配置
API_KEY=

# solarwinds配置
SW_USERNAME=
SW_PASSWORD=